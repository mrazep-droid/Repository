local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Config = {
    FIREBASE_URL = "https://your-database-id.firebaseio.com/data.json",
    POLL_INTERVAL = 1.5,
    COMMAND_TIMEOUT = 15,
    MAX_CACHE_SIZE = 100
}

local Logger = {
    Write = function(self, category, level, message)
        local timestamp = os.date("%H:%M:%S")
        print(string.format("[%s] [%s] [%s]: %s", timestamp, category:upper(), level:upper(), message))
    end
}

local Context = {
    Config = Config,
    LocalPlayer = LocalPlayer
}

function Context:GetLiveState()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    return {
        Character = char,
        Humanoid = hum,
        RootPart = root,
        IsAlive = (hum and hum.Health > 0) == true
    }
end

local CacheManager = { Map = {}, Queue = {}, Head = 1 }

function CacheManager:IsDuplicate(id)
    return self.Map[id] == true
end

function CacheManager:Mark(id)
    if not id or self.Map[id] then return end
    
    local head = self.Head
    local oldId = self.Queue[head]
    
    if oldId then
        self.Map[oldId] = nil
    end
    
    self.Queue[head] = id
    self.Map[id] = true
    
    self.Head = (head % Config.MAX_CACHE_SIZE) + 1
end

local Registry = { _storage = {} }

function Registry:Register(commandName, definition)
    definition.Aliases = definition.Aliases or {}
    definition.Requirements = definition.Requirements or {}
    
    self._storage[commandName:lower()] = definition
    for _, alias in ipairs(definition.Aliases) do
        self._storage[alias:lower()] = definition
    end
end

function Registry:Get(commandName)
    if type(commandName) ~= "string" then return nil end
    return self._storage[commandName:lower()]
end

local Handlers = {}

function Handlers.Reset(ctx, liveState, payload)
    liveState.Humanoid.Health = 0
    return true, "Character core forced to respawn"
end

function Handlers.Freeze(ctx, liveState, payload)
    liveState.RootPart.Anchored = true
    return true, "Physical position anchored"
end

function Handlers.Unfreeze(ctx, liveState, payload)
    liveState.RootPart.Anchored = false
    return true, "Physical position released"
end

function Handlers.WalkSpeed(ctx, liveState, payload)
    local targetSpeed = tonumber(payload.message) or 16
    liveState.Humanoid.WalkSpeed = targetSpeed
    return true, "Walkspeed adjusted to " .. targetSpeed
end

Registry:Register("reset", {
    Name = "Reset", 
    Description = "Mereset karakter.", 
    Requirements = { Humanoid = true, Alive = true }, 
    Handler = Handlers.Reset
})

Registry:Register("freeze", {
    Name = "Freeze", 
    Description = "Mengunci posisi.", 
    Aliases = { "anchor" }, 
    Requirements = { Root = true }, 
    Handler = Handlers.Freeze
})

Registry:Register("unfreeze", {
    Name = "Unfreeze", 
    Description = "Membuka posisi.", 
    Aliases = { "unanchor" }, 
    Requirements = { Root = true }, 
    Handler = Handlers.Unfreeze
})

Registry:Register("walkspeed", {
    Name = "WalkSpeed", 
    Description = "Mengatur kecepatan.", 
    Aliases = { "ws", "speed" }, 
    Requirements = { Humanoid = true }, 
    Handler = Handlers.WalkSpeed
})

local Dispatcher = {}

local RequirementValidators = {
    Character = function(d) 
        return d.Character ~= nil and d.Character:IsDescendantOf(workspace), "Character missing from workspace" 
    end,
    Humanoid  = function(d) 
        return d.Humanoid ~= nil and d.Humanoid:IsDescendantOf(workspace), "Humanoid missing from workspace" 
    end,
    Root      = function(d) 
        return d.RootPart ~= nil and d.RootPart:IsDescendantOf(workspace), "HumanoidRootPart missing from workspace" 
    end,
    Alive     = function(d) 
        return d.IsAlive == true, "Execution denied: Character is dead" 
    end
}

function Dispatcher:Route(payload, ctx)
    if type(payload) ~= "table" or not payload.id or not payload.command then return end
    
    local commandTime = tonumber(payload.timestamp) or 0
    if commandTime > 9999999999 then 
        commandTime = commandTime / 1000 
    end
    
    local timeDiff = os.time() - commandTime
    if timeDiff > Config.COMMAND_TIMEOUT then 
        return Logger:Write("Dispatcher", "Warn", string.format("Command '%s' dropped: Stale by %ds", payload.command, timeDiff)) 
    end
    
    if CacheManager:IsDuplicate(payload.id) then return end
    CacheManager:Mark(payload.id)
    
    local cmdDef = Registry:Get(payload.command)
    if not cmdDef then 
        return Logger:Write("Dispatcher", "Warn", "No registered handler for: " .. tostring(payload.command)) 
    end
    
    local liveState = ctx:GetLiveState()
    for reqName, isRequired in pairs(cmdDef.Requirements) do
        if isRequired then
            local passed, err = RequirementValidators[reqName](liveState)
            if not passed then 
                return Logger:Write("Executor", "Failed", string.format("[%s] Requirement failed: %s", cmdDef.Name, err)) 
            end
        end
    end
    
    local success, cmdOk, msg = pcall(cmdDef.Handler, ctx, liveState, payload)
    if success and cmdOk then
        Logger:Write("Executor", "Success", string.format("[%s] -> %s", cmdDef.Name, msg))
    else
        Logger:Write("Executor", "Error", string.format("[%s] Runtime crash: %s", cmdDef.Name, tostring(msg)))
    end
end

function Dispatcher:ProcessFrame(dataFrame, ctx)
    if type(dataFrame) ~= "table" then return end
    if dataFrame.id ~= nil then
        self:Route(dataFrame, ctx)
    else
        for _, subPayload in pairs(dataFrame) do
            if type(subPayload) == "table" and subPayload.id ~= nil then
                self:Route(subPayload, ctx)
            end
        end
    end
end

local Network = {}

function Network:FetchPayload(url)
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if req then
        local success, res = pcall(req, { Url = url, Method = "GET" })
        if success and res and res.StatusCode == 200 then
            return res.Body
        end
    end
    
    local success, body = pcall(function()
        return game:HttpGet(url)
    end)
    if success and body then return body end
    
    local successAsync, bodyAsync = pcall(function()
        return HttpService:GetAsync(url)
    end)
    if successAsync and bodyAsync then return bodyAsync end
    
    return nil
end

local function Main()
    Logger:Write("System", "Info", "Boot sequence completed. Engine is active.")
    
    while true do
        local rawJson = Network:FetchPayload(Config.FIREBASE_URL)
        
        if rawJson and rawJson ~= "null" then
            local decodeOk, parsedTree = pcall(HttpService.JSONDecode, HttpService, rawJson)
            
            if decodeOk and type(parsedTree) == "table" then
                local frameContext = Context
                
                if parsedTree.all then 
                    Dispatcher:ProcessFrame(parsedTree.all, frameContext) 
                end
                if parsedTree[LocalPlayer.Name] then 
                    Dispatcher:ProcessFrame(parsedTree[LocalPlayer.Name], frameContext) 
                end
            end
        end
        
        task.wait(Config.POLL_INTERVAL)
    end
end

task.spawn(Main)
