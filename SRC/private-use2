local function req(method, url, body)
    local r = (syn and syn.request) or (http and http.request) or http_request or request
    if not r then return nil end
    local ok, res = pcall(r, {Url=url, Method=method, Headers=body and {["Content-Type"]="application/json"} or {}, Body=body})
    return ok and res or nil
end

local function get(url)
    local r = req("GET", url)
    if r and r.StatusCode == 200 then return r.Body end
    local ok, b = pcall(game.HttpGet, game, url)
    return ok and b or nil
end

