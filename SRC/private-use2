end)

-- SPEED CORE (AKURAT + STABLE)
RunService.RenderStepped:Connect(function()
	local seat = getVehicle()
	if not seat then return end

	local target = tonumber(input.Text)
	if not target then return end
	if target > 350 then target = 350 end

	local dir = seat.CFrame.LookVector

	seat.Throttle = enabled and 1 or 0

	if enabled then
		local vel = seat.AssemblyLinearVelocity
		local forwardSpeed = vel:Dot(dir)
		local error = target - forwardSpeed

		seat.AssemblyLinearVelocity = vel + dir * (error * 0.12)
	end
end)

