local HttpService = game:GetService("HttpService")
local LocalPlayer = game:GetService("Players").LocalPlayer

local Config = {
    URL = "https://your-database-id.firebaseio.com/data.json",
    TIMEOUT = 15,
    INTERVAL = 1.5
}

local Cache = { Map = {}, Queue = {}, Head = 1 }

local Handlers = {
    ["reset"] = function(state, msg) 
        state.Hum.Health = 0 
    end,
    ["freeze"] = function(state, msg) 
        state.Root.Anchored = true 
    end,
    ["unfreeze"] = function(state, msg) 
        state.Root.Anchored = false 
    end,
    ["walkspeed"] = function(state, msg) 
        state.Hum.WalkSpeed = tonumber(msg) or 16 
    end
}

local function GetLiveState()
    local c = LocalPlayer.Character
    local h = c and c:FindFirstChildOfClass("Humanoid")
    local r = c and c:FindFirstChild("HumanoidRootPart")
    
    if c and h and r and h.Health > 0 and c:IsDescendantOf(workspace) then
        return { Char = c, Hum = h, Root = r }
    end
    return nil
end

local function ProcessPayload(payload)
    if type(payload) ~= "table" or not payload.id or not payload.command then return end
    
    local ts = tonumber(payload.timestamp) or 0
    if ts > 9999999999 then ts = ts / 1000 end
    if os.time() - ts > Config.TIMEOUT then return end
    
    if Cache.Map[payload.id] then return end
    
    local oldId = Cache.Queue[Cache.Head]
    if oldId then Cache.Map[oldId] = nil end
    Cache.Queue[Cache.Head] = payload.id
    Cache.Map[payload.id] = true
    Cache.Head = (Cache.Head % 100) + 1

    local action = Handlers[payload.command:lower()]
    if not action then return end

    local state = GetLiveState()
    if not state then return end

    pcall(action, state, payload.message)
end

local function FetchData()
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    local body = nil
    
    if req then
        local s, res = pcall(req, { Url = Config.URL, Method = "GET" })
        if s and res and res.StatusCode == 200 then body = res.Body end
    end
    
    if not body then
        pcall(function() body = game:HttpGet(Config.URL) end)
    end
    
    if not body then
        pcall(function() body = HttpService:GetAsync(Config.URL) end)
    end
    
    return body
end

task.spawn(function()
    while true do
        local raw = FetchData()
        
        if raw and raw ~= "null" then
            local s, tree = pcall(HttpService.JSONDecode, HttpService, raw)
            
            if s and type(tree) == "table" then
                local function Route(node)
                    if type(node) ~= "table" then return end
                    if node.id then
                        ProcessPayload(node)
                    else
                        for _, sub in pairs(node) do
                            if type(sub) == "table" then ProcessPayload(sub) end
                        end
                    end
                end
                
                Route(tree.all)
                Route(tree[LocalPlayer.Name])
            end
        end
        
        task.wait(Config.INTERVAL)
    end
end)
